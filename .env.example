# Copy to .env and adjust. .env is gitignored; .env.example is committed as the template.

# Which auth profile the helper scripts / CLI use.
DATABRICKS_CONFIG_PROFILE=coldstart

# Unity Catalog target (must match the bundle variables in databricks.yml).
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=genai

# --- Enterprise / air-gapped package resolution (usually unset on Free Edition) ---
# In locked-down environments there is no open PyPI; packages come from an internal
# Artifactory/Nexus mirror. These are the standard pip knobs - set them so BOTH the
# local helper scripts AND the Databricks compute resolve from the internal index.
# Confirm the exact values (and whether they belong on the job or the workspace) with
# your platform team; a workspace-level private PyPI mirror is the other common option.
# PIP_INDEX_URL=https://artifactory.YOURCO.com/artifactory/api/pypi/pypi-remote/simple
# PIP_EXTRA_INDEX_URL=https://pypi.org/simple
# PIP_TRUSTED_HOST=artifactory.YOURCO.com
