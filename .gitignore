# --- Databricks ---
# Bundle deploy state + local cache the CLI/VS Code extension generate. Never commit.
.databricks/

# --- Python ---
.venv/
.venv*/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Local env/secrets (commit the template, not the real thing) ---
.env
.env.*
!.env.example

# --- Local proof/scratch artifacts (regenerated by the helper scripts) ---
_downloaded-report.md
_outbox/

# --- Personal working notes and printouts (kept local by choice) ---
print/
work/

# --- VS Code ---
# Ignore the folder's churn, but DO commit settings.json (team-shared config).
.vscode/*
!.vscode/settings.json

# raw Claude Code session transcript (private, never commit)
.session-archive/
